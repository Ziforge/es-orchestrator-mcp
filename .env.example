# Expert Sleepers Orchestrator Configuration
# Copy to .env and adjust for your setup

# FH-2 MIDI ports (substring match, auto-detects "FH-2" if empty)
FH2_OUTPUT_PORT=
FH2_INPUT_PORT=
FH2_MIDI_CHANNEL=1

# ES-9 MIDI ports (substring match, auto-detects "ES-9" if empty)
ES9_OUTPUT_PORT=
ES9_INPUT_PORT=
# ES-9 audio device for CV generation (empty = no audio, MIDI-only)
ES9_AUDIO_DEVICE=
ES9_SAMPLE_RATE=48000

# Disting NT MIDI ports (substring match, auto-detects "Disting NT" if empty)
DISTING_NT_OUTPUT_PORT=
DISTING_NT_INPUT_PORT=
DISTING_NT_SYSEX_ID=0
DISTING_NT_MIDI_CHANNEL=1

# Auto-connect all modules on server start
AUTO_CONNECT=false
